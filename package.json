{
  "name": "collab-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web",
    "lint:fix": "npm run lint:fix --workspace=web",
    "format": "npm run format --workspace=web",
    "format:check": "npm run format:check --workspace=web",
    "typecheck": "npm run typecheck --workspace=web",
    "typecheck:backend": "cd apps/server && python -m mypy .",
    "prepare": "husky",
    "pre-commit": "npx lint-staged && python -m pre_commit run --config apps/server/.pre-commit-config.yaml"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --config ./apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/web/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
